# Copy this file to .env.local and fill in your values

# Storage API base URL
STORAGE_API_BASE_URL=https://public.quikstor.com

# Your company code (used in API paths)
NEXT_PUBLIC_COMPANY_CODE=

# Your facility code (used in API paths) — can also be set per-session
NEXT_PUBLIC_FACILITY_CODE=

# Secret used to sign session cookies (generate with: openssl rand -base64 32)
SESSION_SECRET=
